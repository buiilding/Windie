{
  "name": "@windie/sdk",
  "version": "0.1.0",
  "description": "Public TypeScript SDK for waking agents and routing local runtime tools.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "windie",
    "windieos",
    "agents",
    "agent-runtime",
    "computer-use"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./cjs/index.js"
    }
  },
  "files": [
    "dist",
    "cjs"
  ],
  "scripts": {
    "build": "npm run clean && npm run build:esm && npm run build:cjs",
    "build:esm": "tsc -p tsconfig.build.json",
    "build:cjs": "tsc -p tsconfig.cjs.json && node scripts/write-cjs-package.mjs",
    "clean": "node scripts/clean-build-output.mjs",
    "prepack": "npm run build"
  },
  "dependencies": {
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
