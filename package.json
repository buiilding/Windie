{
  "name": "desktop-assistant-frontend",
  "private": true,
  "version": "0.6.1",
  "type": "module",
  "main": "src/main/index.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "package": "npm run build && electron-builder",
    "package:win": "npm run build && electron-builder --win nsis",
    "package:mac": "npm run build && electron-builder --mac dmg zip",
    "package:linux": "npm run build && electron-builder --linux AppImage deb rpm",
    "package:win:bundled-python": "npm run build && electron-builder --config electron-builder.bundled-python.yml --win nsis",
    "package:mac:bundled-python": "npm run build && electron-builder --config electron-builder.bundled-python.yml --mac dmg zip",
    "package:linux:bundled-python": "npm run build && electron-builder --config electron-builder.bundled-python.yml --linux AppImage deb rpm",
    "build:sidecar-runtime": "bash ../scripts/build-sidecar-runtime",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "electron": "ELECTRON_DISABLE_SANDBOX=1 electron .",
    "test": "NODE_OPTIONS=--no-deprecation jest --config jest.config.cjs",
    "test:ci": "NODE_OPTIONS=--no-deprecation jest --config jest.config.cjs --runInBand",
    "test:shell": "node src/main/test_shell.cjs"
  },
  "dependencies": {
    "clipboardy": "^3.0.0",
    "dompurify": "^3.3.1",
    "marked": "^17.0.1",
    "node-window-manager": "^2.2.4",
    "pngjs": "^7.0.0",
    "prop-types": "^15.8.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "systeminformation": "^5.21.0",
    "uuid": "^8.3.2",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@babel/core": "^7.28.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.23.3",
    "@babel/preset-typescript": "^7.27.1",
    "@testing-library/jest-dom": "^6.1.4",
    "@testing-library/react": "^14.1.2",
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@vitejs/plugin-react": "^4.0.3",
    "babel-plugin-transform-import-meta": "^2.2.1",
    "baseline-browser-mapping": "^2.9.19",
    "electron": "^27.1.2",
    "electron-builder": "^24.13.3",
    "eslint": "^8.45.0",
    "eslint-plugin-react": "^7.32.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.3",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "json-schema-to-typescript": "^15.0.4",
    "vite": "^4.4.5",
    "zustand": "^5.0.8"
  }
}
